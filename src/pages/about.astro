---
import Breadcrumbs from '@/components/breadcrumbs.astro'
import FeaturedProjectCard from '@/components/featured-project-card.astro'
import Link from '@/components/link.astro'
import PageHead from '@/components/page-head.astro'
import { Badge } from '@/components/ui/badge'
import Layout from '@/layouts/layout.astro'
import { getAllProjects } from '@/lib/data-utils'
import { Icon } from 'astro-icon/components'

const allProjects = await getAllProjects()
const featuredIds = ['division1d', 'crimson-pandemic']
const featured = featuredIds
  .map((id) => allProjects.find((p) => p.id === id))
  .filter(Boolean)

const skills = [
  {
    category: 'Language',
    items: ['C#', 'C++', 'C', 'JS', 'TS', 'Lua', 'Python'],
  },
  {
    category: 'Client',
    items: [
      'Unity',
      'Mirror',
      'Steamworks',
      'Reflex',
      'ECS',
      'Job System',
      'Burst',
    ],
  },
  { category: 'Server', items: ['.NET', 'Redis', 'Oracle', 'TCP/UDP'] },
  { category: 'Infra', items: ['Docker', 'Oracle', 'CI/CD'] },
]
---

<Layout class="max-w-3xl">
  <PageHead slot="head" title="About" />
  <Breadcrumbs
    items={[{ label: 'About', href: '/about', icon: 'lucide:user' }]}
  />

  <section class="not-prose flex flex-col items-center sm:clear-both sm:block">
    <img
      src="/web-app-manifest-512x512.png"
      alt="hyuki"
      class="ring-border mb-4 size-28 shrink-0 rounded-full ring-1 sm:float-left sm:mr-6 sm:mb-2 sm:size-48 sm:[shape-outside:circle(50%)]"
    />
    <div
      class="text-muted-foreground text-center text-base leading-relaxed sm:pt-4 sm:text-left"
    >
      <p>
        안녕하세요! 서브컬처 게임을 좋아하고, <br class="hidden sm:inline" /> 유니티로
        게임을 만드는 개발자입니다.
        <br class="hidden sm:inline" />
        새로운 기술은 일단 부딪혀보는 스타일이라, <br
          class="hidden sm:inline"
        /> 개인 프젝으로 ECS나 Reflex를 직접 구현해보고 <br
          class="hidden sm:inline"
        /> 팀 프젝을 통해 최적화와 네트워크도 설계하고 구현했습니다 !<br
          class="hidden sm:inline"
        /> 애니메이션과 딸기라떼를 좋아합니다 !!! 🍓🥛
      </p>
    </div>
  </section>

  <section class="not-prose flex flex-col gap-y-4">
    <h2 class="text-lg font-semibold">Skills</h2>
    <div class="flex flex-col gap-y-3">
      {
        skills.map((group) => (
          <div class="flex flex-col gap-y-1.5">
            <span class="text-muted-foreground text-xs font-medium">
              {group.category}
            </span>
            <div class="flex flex-wrap gap-1.5">
              {group.items.map((item) => (
                <Badge variant="muted">{item}</Badge>
              ))}
            </div>
          </div>
        ))
      }
    </div>
  </section>

  <section class="not-prose flex flex-col gap-y-4">
    <div class="flex items-center gap-2">
      <h2 class="text-lg font-semibold">Featured Projects</h2>
      <span class="text-muted-foreground/50">·</span>
      <Link
        href="/project"
        class="text-muted-foreground hover:text-foreground flex items-center gap-x-1 text-sm"
      >
        모든 프로젝트 보기
        <Icon name="lucide:arrow-right" class="size-4" />
      </Link>
    </div>
    <div class="flex flex-col gap-4">
      {featured.map((project) => <FeaturedProjectCard project={project!} />)}
    </div>
  </section>
</Layout>
